{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "jest",
  "jest": {
    "projectType": "custom",
    "configFile": "jest.config.cjs"
  },
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/app.js",
    "src/resilience/**/*.js",
    "src/services/CheckoutServiceRefactored.js",
    "src/services/PedidoConsultaService.js",
    "src/validation/PedidoValidator.js"
  ],
  "reporters": [
    "progress",
    "clear-text",
    "html",
    "json"
  ],
  "htmlReporter": {
    "fileName": "reports/mutation/index.html"
  },
  "jsonReporter": {
    "fileName": "reports/mutation/mutation.json"
  },
  "clearTextReporter": {
    "reportScoreTable": true,
    "reportMutants": true,
    "reportTests": false
  },
  "thresholds": {
    "high": 90,
    "low": 80,
    "break": null
  },
  "concurrency": 2,
  "timeoutMS": 10000
}
